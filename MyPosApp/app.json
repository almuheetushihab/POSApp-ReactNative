{
  "expo": {
    "name": "MyPosApp",
    "slug": "MyPosApp",
    "scheme": "myapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/pos_app_logo.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/pos_app_logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.almuheetu.MyPosApp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/pos_app_logo.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.almuheetu.MyPosApp"
    },
    "web": {
      "favicon": "./assets/pos_app_logo.jpeg"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-localization"
    ]
  }
}
